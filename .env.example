# Configuration file for BuildLedger AI System

# Flask Backend Settings
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=True
FLASK_ENV=development

# API Settings
API_TIMEOUT=30
CORS_ORIGINS=*

# Model Settings
MODEL_PATH=model.pkl
VECTORIZER_PATH=vectorizer.pkl
MODEL_NAME_PATH=model_name.pkl

# Training Data
DATASET_PATH=../dataset/Construction_Data_PM_Tasks_All_Projects.csv

# Feature Engineering
TFIDF_MAX_FEATURES=7000
TFIDF_NGRAM_RANGE=1,2
TEST_SIZE=0.2
RANDOM_STATE=42

# Hyperparameter Tuning
CV_FOLDS=3
ENABLE_TUNING=True

# Categories
CATEGORIES=Material,Labor,Transport,Equipment,Subcontractor

# Frontend
FRONTEND_PORT=3000
LIVE_RELOAD=True

# Logging
LOG_LEVEL=INFO
LOG_FILE=buildledger.log
